# ── LLM APIs (Router Groq → DeepSeek) ──
DEEPSEEK_API_KEY=sua_chave_aqui
GROQ_API_KEY=sua_chave_aqui

# ── Supabase (futuro) ──
SUPABASE_URL=sua_url_aqui
SUPABASE_KEY=sua_key_aqui

# ── Email SMTP (nodemailer) ──
SMTP_EMAIL=seu_email_aqui
SMTP_PASSWORD=sua_senha_aqui
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM_NAME=G5X
EMAIL_TEMPLATES_DIR=./email-templates

# ── Calendly (Agendamento) ──
CALENDLY_TOKEN=seu_token_aqui
CALENDLY_USER_URI=https://api.calendly.com/users/SEU_ID
CLOSER_AVAILABILITY={"weekdays":["seg","ter","qua","qui","sex"],"hours":["09:00","10:00","11:00","14:00","15:00","16:00"],"timezone":"America/Sao_Paulo"}

# ── LinkedIn ──
LINKEDIN_CONFIGURED=false
LINKEDIN_STRATEGY=api
LINKEDIN_API_KEY=sua_chave_aqui
LINKEDIN_API_BASE=https://linkedin-api8.p.rapidapi.com

# ── Redis (BullMQ — opcional, funciona sem) ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── MCPs (opcional) ──
WHATSAPP_CONFIGURED=false

# ── Engine Autônomo ──
AGENT_AUTO_START=true
AGENT_HEARTBEAT_SECONDS=120
AGENT_MAX_PER_CYCLE=5

# ── Servidor ──
PORT=3000
