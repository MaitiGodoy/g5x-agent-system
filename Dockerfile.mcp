# ═══════════════════════════════════════════
# G5X MCP — Dockerfile (Node only, no Python)
# ═══════════════════════════════════════════
FROM node:20-alpine

LABEL maintainer="G5X Team"
LABEL description="G5X MCP Service"

ENV NODE_ENV=production
ENV PORT=3001

WORKDIR /app

# Copiar deps e instalar
COPY package*.json ./
RUN npm ci --omit=dev && npm cache clean --force

# Copiar código
COPY server.js api.js agent.js ./
COPY tools/ ./tools/
COPY mcps/ ./mcps/
COPY public/ ./public/

# Criar diretórios
RUN mkdir -p /app/data && chown -R node:node /app

USER node

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:$PORT/ || exit 1
